# ========================================

# BUILD OUTPUT (ALL PROJECTS)

# ========================================

**/bin/
**/obj/
**/out/
**/publish/
**/wwwroot/dist/
**/wwwroot/build/

# ========================================

# USER / IDE FILES

# ========================================

# Visual Studio

.vs/
*.suo
*.user
*.userosscache
*.sln.docstates

# VS Code

.vscode/*
!.vscode/settings.json
!.vscode/launch.json
!.vscode/tasks.json
!.vscode/extensions.json

# Rider

.idea/
*.sln.iml

# ========================================

# LOGS

# ========================================

*.log

# ========================================

# OS FILES

# ========================================

.DS_Store
Thumbs.db

# ========================================

# NUGET / PACKAGES

# ========================================

*.nupkg
*.snupkg
.nuget/
packages/
artifacts/

# ========================================

# ENVIRONMENT & SECRETS

# ========================================

# Env files

.env
.env.*
!.env.example

# .NET configs with secrets

**/appsettings.Development.json
**/appsettings.Local.json
secrets.json

# User secrets (CLI storage)

**/secrets/*

# ========================================

# DATABASE / MIGRATIONS (OPTIONAL)

# ========================================

# Uncomment ONLY if you generate DB locally and don't want to track it

# *.db

# *.sqlite

# *.mdf

# *.ldf

# ========================================

# TEST RESULTS

# ========================================

TestResults/
*.trx
*.coverage
*.coveragexml

# ========================================

# DOCKER

# ========================================

docker-compose.override.yml
**/docker-data/
**/volumes/

# ========================================

# FRONTEND (if exists)

# ========================================

frontend/node_modules/
frontend/dist/
frontend/build/
frontend/.env
frontend/.env.*

# ========================================

# STATIC FILE CACHE (API)

# ========================================

**/wwwroot/lib/
**/wwwroot/*.map

# ========================================

# RESHARPER / ANALYZERS

# ========================================

_ReSharper*/
*.DotSettings.user

# ========================================

# DOTNET CLI

# ========================================

.dotnet/

# ========================================

# TEMP FILES

# ========================================

*.tmp
*.temp
*.bak
~$*

# ========================================

# FILE UPLOADS (IMPORTANT FOR YOUR APP)

# ========================================

# If your GarageHub stores images/files locally:

**/uploads/
**/images/
**/files/

# ========================================

# GENERATED CODE

# ========================================

# Swagger / OpenAPI generated clients (if any)

**/Generated/

# ========================================

# KEEP IMPORTANT EMPTY FOLDERS

# ========================================

!**/uploads/.gitkeep
!**/images/.gitkeep
